# ============================================================
# Production Environment — copy to .env.prod and fill in values
# ============================================================

# AWS
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-avatar-bucket
CLOUDFRONT_DOMAIN=

# Database  (RDS recommended in production)
DATABASE_URL=postgresql://avatar_user:STRONG_PASSWORD@postgres:5432/avatar_db
DATABASE_NAME=avatar_db
DATABASE_USER=avatar_user
DATABASE_PASSWORD=STRONG_PASSWORD_HERE

# Redis  (ElastiCache recommended in production)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
ELEVENLABS_API_KEY=

# Application
SECRET_KEY=generate-with-openssl-rand-hex-32
JWT_SECRET_KEY=generate-with-openssl-rand-hex-32
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING

# Avatar Engine — musetalk for GPU lip-sync, simple for fallback
AVATAR_ENGINE=musetalk
AVATAR_RESOLUTION=512
AVATAR_FPS=25
MUSETALK_PATH=/app/models/MuseTalk

# Isolated ML microservices
STT_URL=http://stt:8001
TTS_URL=http://tts:8002
MUSETALK_URL=http://musetalk:8003
MEDIA_ROOT=/media

# Storage — use S3 in production
USE_LOCAL_STORAGE=false
LOCAL_STORAGE_PATH=uploads

# LLM
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# TTS (tts container)
TTS_PROVIDER=chatterbox
TTS_VOICE=default

# STT (stt container)
STT_PROVIDER=whisper
WHISPER_MODEL=large-v3-turbo

# Frontend (point to your domain / EC2 public IP)
BACKEND_URL=https://yourdomain.com
WS_URL=wss://yourdomain.com
FRONTEND_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# Security
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
