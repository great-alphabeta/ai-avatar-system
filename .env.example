# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=avatar-system-storage
CLOUDFRONT_DOMAIN=

# Database Configuration
DATABASE_URL=postgresql://avatar_user:change_this_password@postgres:5432/avatar_db
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=avatar_db
DATABASE_USER=avatar_user
DATABASE_PASSWORD=change_this_password

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Application Settings
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# LLM Configuration
# anthropic | openai | ollama (local & free — runs against http://localhost:11434/v1)
LLM_PROVIDER=anthropic
# Claude (2026): claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5
# OpenAI: e.g. gpt-4o, gpt-4o-mini (also requires LLM_PROVIDER=openai)
# Ollama: e.g. llama3.1, qwen2.5 (requires LLM_PROVIDER=ollama)
LLM_MODEL=claude-sonnet-4-6
# Optional: point the OpenAI-compatible client elsewhere (Ollama, vLLM,
# LM Studio, OpenRouter). Leave empty for api.openai.com.
OPENAI_BASE_URL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Avatar Engine
AVATAR_ENGINE=musetalk
AVATAR_RESOLUTION=512

# Isolated ML microservices (Docker Compose service names / ports)
STT_URL=http://stt:8001
TTS_URL=http://tts:8002
MUSETALK_URL=http://musetalk:8003
# For local (non-Docker) API against compose ML services, use localhost ports
# after publishing them, or keep the docker-network hostnames above.
STT_TIMEOUT_SECONDS=120
TTS_TIMEOUT_SECONDS=180
MUSETALK_TIMEOUT_SECONDS=300
MEDIA_ROOT=/media

# STT Configuration (consumed by the stt container)
STT_PROVIDER=whisper
# tiny | base | small | medium | large-v3 | large-v3-turbo
# large-v3-turbo: best 2026 sweet spot — recommended for GPU. Fall back to base/small on CPU.
WHISPER_MODEL=large-v3-turbo

# TTS Configuration (consumed by the tts container)
# chatterbox (voice cloning, 23 languages). Automatic fallback chain when the
# model can't load: edge-tts (free neural voices) -> gtts.
TTS_PROVIDER=chatterbox
TTS_VOICE=default

# Security
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# WebSocket
WS_MAX_CONNECTIONS=1000
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# Video Settings
VIDEO_FPS=25
VIDEO_CODEC=h264
VIDEO_BITRATE=2000k

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# Frontend URL
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
